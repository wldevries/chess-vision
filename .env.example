# Azure Blob Storage for the captured dataset (scripts/sync_blob.py). The account
# connection string is shared with the hive-vision project; the container defaults to
# "chess". Layout mirrors the local tree: source/<relpath>, store/<relpath>,
# labels.jsonl at the root (models/ later, same container).
STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=chess

# MinIO / S3 dataset storage (legacy backend, scripts/sync_captures.py). Copy to .env
# and fill in real values. Create an access key with:
#   mc admin accesskey create <alias> --access-key chess-app
# (MinIO Community Edition no longer exposes this in the web console.)
MINIO_ENDPOINT_URL=http://workstation.lan:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=chess

# Optional: Lichess personal access token (lichess.org/account/oauth/token, no
# scope needed) for the capture app's live "Next puzzle" button. Without it,
# puzzles are fetched anonymously; with it, they're de-duplicated against your
# solved puzzles and difficulty is honoured. The API has no user/password auth.
LICHESS_TOKEN=

# Label Studio REST API, for programmatically updating capture corner annotations
# (the corner-validation tool patches corners on existing tasks in the project).
# Token: Label Studio -> Account & Settings -> Access Token.
LABEL_STUDIO_URL=http://workstation:8080
LABEL_STUDIO_TOKEN=
LABEL_STUDIO_PROJECT=chess-vision-2
