# MinIO / S3 dataset storage. Copy to .env and fill in real values.
# Create an access key with: mc admin accesskey create <alias> --access-key chess-app
# (MinIO Community Edition no longer exposes this in the web console.)
MINIO_ENDPOINT_URL=http://workstation.lan:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=chess

# Optional: Lichess personal access token (lichess.org/account/oauth/token, no
# scope needed) for the capture app's live "Next puzzle" button. Without it,
# puzzles are fetched anonymously; with it, they're de-duplicated against your
# solved puzzles and difficulty is honoured. The API has no user/password auth.
LICHESS_TOKEN=
